# --- Server ---
NODE_ENV=development
PORT=5000

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/taxilik

# --- Redis (Socket.IO fan-out, rate-limits, ride viewers). Optional in dev. ---
# REDIS_URL=redis://:password@127.0.0.1:6379

# --- CORS (comma-separated). Empty => allow all (dev only). ---
# CORS_ORIGINS=https://taxilik.ma,https://www.taxilik.ma

# --- Uploads (mount a volume in prod) ---
# UPLOAD_DIR=/data/uploads

# --- Auth (access + rotating refresh tokens) ---
JWT_SECRET=change-me-to-a-long-random-string
OTP_SECRET=change-me-to-a-different-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_TTL_DAYS=30

# --- SMTP (OTP email delivery) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TaxiLik.ma <no-reply@taxilik.ma>

# --- OTP ---
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# --- Legal tariff (DH) ---
FARE_PER_KM=0.50
FARE_PICKUP_DAY=2.00
FARE_PICKUP_NIGHT=4.00
FARE_NIGHT_START_HOUR=20
FARE_NIGHT_END_HOUR=6
FARE_MIN=0

# --- Matching ---
MATCH_RADIUS_METERS=3000

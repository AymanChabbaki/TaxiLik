# docker-compose secrets (copy to .env). Used to substitute ${VARS} in compose.
MONGO_USER=taxilik
MONGO_PASSWORD=change-me-strong-password
REDIS_PASSWORD=change-me-strong-redis-password
# Comma-separated allowed origins (your web domain + Expo, etc.)
CORS_ORIGINS=https://taxilik.ma,https://www.taxilik.ma

# Hostname for TLS + server name. Use your VPS hostname until you buy a domain
# (Hostinger gives you one that resolves to your IP, e.g. srvXXXXX.hstgr.cloud).
# Change to taxilik.ma once you own it.
DOMAIN=srv1765015.hstgr.cloud

# Edge selection: "plain" (nginx) or "waf" (OWASP ModSecurity CRS). Pick one.
COMPOSE_PROFILES=plain
# When COMPOSE_PROFILES=waf: start as DetectionOnly to tune, then set On.
MODSEC_RULE_ENGINE=DetectionOnly

# Mongo backups (mongo-backup service)
BACKUP_INTERVAL=86400
BACKUP_KEEP_DAYS=7
